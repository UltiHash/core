version: '3'

services:
    deduplicator:
        image: uh/test
        container_name: dedupe
        restart: always
        volumes:
            - "$<TARGET_FILE:uh-cluster>:/uh-cluster"
        entrypoint: [ "/uh-cluster", "deduplicator", "0" ]
        healthcheck:
            test: [ "CMD", "lsof", "-i", "UDP:8084" ]
            timeout: 1s
            interval: 5s
            retries: 5

    storage:
        image: uh/test
        container_name: data
        restart: always
        volumes:
            - "$<TARGET_FILE:uh-cluster>:/uh-cluster"
        entrypoint: [ "/uh-cluster", "storage", "0" ]
        healthcheck:
            test: [ "CMD", "lsof", "-i", "UDP:8082" ]
            timeout: 1s
            interval: 5s
            retries: 5

    directory:
        image: uh/test
        container_name: directory
        restart: always
        volumes:
            - "$<TARGET_FILE:uh-cluster>:/uh-cluster"
        entrypoint: [ "/uh-cluster", "directory", "0" ]
        healthcheck:
            test: [ "CMD", "lsof", "-i", "UDP:8083" ]
            timeout: 1s
            interval: 5s
            retries: 5

    entrypoint:
        image: uh/test
        container_name: entrypoint
        restart: always
        volumes:
            - "$<TARGET_FILE:uh-cluster>:/uh-cluster"
        entrypoint: [ "/uh-cluster", "entrypoint", "0" ]
        depends_on:
            deduplicator:
                condition: service_healthy
            storage:
                condition: service_healthy
            directory:
                condition: service_healthy
        ports:
            - "8080:8080"
