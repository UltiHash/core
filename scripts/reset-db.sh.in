#!/bin/bash

[ -z "$UH_DB_USER" ] || [ -z "$UH_DB_PASS" ] || [ -z "$UH_DB_HOSTPORT" ] && {
    echo "You need to set the environment variables UH_DB_HOSTPORT, UH_DB_USER "
    echo "and UH_DB_PASS in order to run this script."
    exit 1
}

databases="uh_directory uh_multipart uh_user"
for db in $databases; do
    echo "DROP DATABASE $db" |
        psql "postgresql://$UH_DB_USER:$UH_DB_PASS@$UH_DB_HOSTPORT/postgres"
done

SQL_PATH=@PROJECT_SOURCE_DIR@/data/sql
BIN_PATH=@PROJECT_BINARY_DIR@

cat $SQL_PATH/provision_databases.sql | psql postgres

for dir in $SQL_PATH/*; do
    if [ -d  "$dir" ]; then
        dbname=$(basename "$dir")
        flyway -locations="filesystem:$dir" -url="jdbc:postgresql://$UH_DB_HOSTPORT/$dbname" -user="$UH_DB_USER" -password="$UH_DB_PASS" migrate
    fi
done

access=$BIN_PATH/tools/uh-cluster-access-client
$access user-add 'root' 'password' 'arn:uh:iam::0:users/root'
$access key-add 'root' 'FANCY-ROOT-KEY' 'SECRET' 86400
$access policy-add 'root' 'allow-all' '{ "Version": "2012-10-17", "Statement": { "Sid":  "AllowAllForRoot", "Effect": "Allow", "Action": "*", "Principal": "arn:uh:iam::0:users/root", "Resource": "*" } }'

$access user-add 'john.doe' 'password' 'arn:uh:iam::0:users/john.doe'
$access key-add 'john.doe' 'NOPQRSTUVWXYZABCDEFG' 'nopqrstuvwxyzabcdefghijklmnabcdefghijklm' 86400
$access policy-add 'john.doe' 'allow-all' '{ "Version": "2012-10-17", "Statement": { "Sid":  "AllowAll", "Effect": "Allow", "Action": "*", "Principal": "arn:uh:iam::0:users/*", "Resource": "*" } }'

$access user-add 'tenant' 'password' 'arn:uh:iam::0:users/tenant'
$access key-add 'tenant' 'HIJKLMNOPQRSTUVWXYZA' 'opqrstuvwxyzabcdefghijklmnopqrstuvwxyzab' 86400
$access policy-add 'tenant' 'allow-all' '{ "Version": "2012-10-17", "Statement": { "Sid":  "AllowAll", "Effect": "Allow", "Action": "*", "Principal": "arn:uh:iam::0:users/*", "Resource": "*" } }'

$access user-add 'iam' 'password' 'arn:uh:iam::0:users/iam'
$access key-add 'iam' 'ABCDEFGHIJKLMNOPQRST' 'abcdefghijklmnopqrstuvwxyzabcdefghijklmn' 86400
$access policy-add 'iam' 'allow-all' '{ "Version": "2012-10-17", "Statement": { "Sid":  "AllowAll", "Effect": "Allow", "Action": "*", "Principal": "arn:uh:iam::0:users/*", "Resource": "*" } }'
